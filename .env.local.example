# Biến môi trường cho FGL Ecosystem
# Sao chép file này thành .env.local và điền giá trị thực

# ── Supabase ──────────────────────────────────────────────────
# Lấy từ: https://supabase.com/dashboard/project/[your-project]/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── DeepSeek AI ───────────────────────────────────────────────
# Lấy từ: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ── Telegram Notifications ────────────────────────────────────
# Tạo bot: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ── Google OAuth (Supabase sẽ xử lý) ─────────────────────────
# Cấu hình tại: Supabase Dashboard > Authentication > Providers > Google
# Không cần thêm biến môi trường ở đây nếu dùng Supabase OAuth

# ── Google Sheets CRM Sync ────────────────────────────────────
GOOGLE_SHEETS_ID=your-google-sheet-id
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key\n-----END PRIVATE KEY-----"

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Feel Great Life
